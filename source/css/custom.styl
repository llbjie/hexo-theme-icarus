// ============================================================
//  Icarus 自定义布局样式
//  文件路径: icarus/source/css/custom.styl
//  使用方法: 在 default.styl 末尾添加 @import 'custom'
// ============================================================

// ── 1. 固定导航栏 ─────────────────────────────────────────────

.navbar.navbar-main
  position: fixed !important
  z-index: 1000
  left: 0
  right: 0
  .container
    max-width: 100% !important
    padding-left: 10rem
    padding-right: 10rem

// 补偿导航栏高度，防止正文被遮住
body > .section
  padding-top: calc(3.25rem + 2rem)