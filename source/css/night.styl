// ============================================================
//  Icarus 夜间模式样式
//  文件路径: icarus/source/css/night.styl
//  使用方法: 在 default.styl 末尾添加 @import 'night'
// ============================================================

// ── 颜色变量 ─────────────────────────────────────────────────
dark-primary-color         = rgb(55, 61, 72)
dark-primary-color-hover   = rgb(67, 74, 86)
dark-primary-color-active  = rgb(44, 49, 58)
dark-font-color            = #c8c8c8    // 主字色（原 #e0e0e0，稍暗）
dark-font-secondary        = #888888    // 次要信息（原 #a0a0a0，稍暗）

// ── 暗色背景 ─────────────────────────────────────────────────
body.night
  // background: #0e1225
  background: #0f1328

// ── 夜间图标切换 ─────────────────────────────────────────────
#universe
  display: none

.navbar-logo, .footer-logo
  .logo-img-dark
    display: none

.night

  // ── 导航栏 ─────────────────────────────────────────────────
  #night-nav #night-icon:before
    content: '\f186'

  .navbar-menu
    background-color: inherit

  .navbar-main .navbar-menu .navbar-item
    &:hover,
    &:focus
      color: #ffffff
      background-color: dark-primary-color

  .navbar,
  .card
    // background-color: rgba(40, 44, 52, 0.5)
    background-color: #1b1f2a
    border: 1px solid rgba(255,255,255,0.05)
    backdrop-filter: none
    -webkit-backdrop-filter: none

  .card
    &:hover
      background-color: rgba(40, 44, 52, 0.8)

  .footer
    background-color: rgba(40, 44, 52, 0.5)
    backdrop-filter: none
    -webkit-backdrop-filter: none
    &:before
      background-color: rgba(40, 44, 52, 0.5)

  // ── 正文 ───────────────────────────────────────────────────
  .content p,
  .content li,
  .content td,
  .content th
    color: #c0c0c0 !important    // 原 #dcdcdc，降低亮度约 15%

  .content code
    color: rgb(180, 165, 110)    // 原 rgb(203,186,125)，稍暗

  .content h1,
  .content h2,
  .content h3,
  .content h4,
  .content h5,
  .content h6
    color: #d0d0d0               // 标题可以比正文稍亮，保留层次

  // ── 字体颜色 ───────────────────────────────────────────────
  body,
  strong,
  time,
  .title,
  .footer,
  .card,
  .navbar-item,
  .navbar-item.is-active,
  .navbar-link,
  .menu-list a,
  .menu-label,
  .level-item,
  .input,
  .textarea,
  .button.is-white,
  .button.is-transparent,
  .article-licensing
    color: dark-font-color

  .media-content,
  .link-muted
    color: dark-font-color !important

  .has-text-grey,
  .media-content .has-text-grey
    color: dark-font-secondary !important

  a
    color: rgb(82, 153, 224)
    &:hover
      color: #ffffff

  // ── 输入框 ─────────────────────────────────────────────────
  .input,
  .textarea
    background-color: dark-primary-color-hover
    border-color: dark-primary-color

  // ── 提示框 (message) ───────────────────────────────────────
  .message.message-immersive
    background-color: #c2c2c2
    .message-body
      color: #222222

  .message.message-immersive.is-info
    background-color: #bdc3c8
    .message-body
      color: #004779

  .message.message-immersive.is-warning
    background-color: #cbc8ba
    .message-body
      color: #5b4b00

  .message.message-immersive.is-danger
    background-color: #c6babe
    .message-body
      color: #79000f

  .message.message-immersive.is-success
    background-color: #bfc7c0
    .message-body
      color: #1e4d1c

  .message.message-immersive.is-primary
    background-color: #bdc0c9
    .message-body
      color: #003790

  // ── 按钮 ───────────────────────────────────────────────────
  .button.is-primary,
  .button.is-light,
  .button.is-small
    background-color: dark-primary-color
    color: dark-font-color
    &:hover,
    &.is-hovered
      color: #ffffff
      background-color: dark-primary-color-hover
    &:active,
    &.is-active
      color: #ffffff
      background-color: dark-primary-color-active

  .button.is-white,
  .button.is-transparent
    background-color: transparent
    &:hover
      background-color: dark-primary-color !important

  // ── 分页 ───────────────────────────────────────────────────
  .pagination .pagination-next,
  .pagination .pagination-previous,
  .pagination-link:not(.is-current)
    color: dark-font-color
    background-color: dark-primary-color
    a
      color: dark-font-color

  .pagination-link.is-current
    background-color: dark-primary-color-hover
    border-color: dark-primary-color-hover

  // ── 引用 / 版权 ────────────────────────────────────────────
  .content blockquote,
  .article-licensing,
  .post-copyright
    background-color: dark-primary-color
    border-color: dark-primary-color-hover

  // ── 表格 ───────────────────────────────────────────────────
  .content table thead td,
  .content table thead th
    color: dark-font-color

  .content table td,
  .content table th
    border-color: dark-primary-color-hover

  // ── 分割线 ─────────────────────────────────────────────────
  hr
    background-color: dark-primary-color-hover

  // ── 标签 / 菜单 ────────────────────────────────────────────
  article.article, article.media
    .title:hover a
      color: dark-font-color !important

  .tag:not(body)
    color: dark-font-color
    background-color: dark-primary-color

  .tag.is-grey
    background-color: dark-primary-color-hover

  .menu-list a:hover
    background-color: dark-primary-color

  .menu-list a.is-active
    background-color: dark-primary-color-hover

  .menu-list li ul
    border-color: dark-primary-color

  // ── 时间轴 ─────────────────────────────────────────────────
  .timeline .media:last-child:after
    background-color: rgb(37, 41, 54)

  .timeline
    border-color: dark-primary-color-hover

  .timeline .media:before
    background-color: dark-primary-color-hover

  // ── 搜索框 ─────────────────────────────────────────────────
  .searchbox
    .searchbox-container,
    .searchbox-header,
    .searchbox-header .searchbox-input,
    .searchbox-header .searchbox-close,
    .searchbox-body,
    .searchbox-result-section,
    .searchbox-result-item
      color: dark-font-color
      background-color: dark-primary-color
      border-color: dark-primary-color-hover

    .searchbox-container .searchbox-result-section .searchbox-result-item:hover,
    .searchbox-container .searchbox-result-section .searchbox-result-item.active,
    .searchbox-container .searchbox-header .searchbox-close:hover
      color: #ffffff
      background-color: dark-primary-color-hover

  // ── 选中高亮 ───────────────────────────────────────────────
  ::selection
    color: #ffffff
    background-color: rgba(52, 109, 167, 0.8)

  ::-moz-selection
    color: #ffffff
    background-color: rgba(52, 109, 167, 0.8)

  input:-webkit-autofill
    -webkit-text-fill-color: dark-font-color !important
    box-shadow: 0 0 0px 1000px dark-primary-color inset

  // ── 评论：Valine ───────────────────────────────────────────
  .v
    .vwrap,
    .vwrap .vheader .vinput
      border-color: dark-primary-color
      background-color: dark-primary-color

    .vwrap .vheader .vinput:focus
      border-color: dark-primary-color-hover

    .vbtn
      color: dark-font-color
      background-color: dark-primary-color
      border-color: dark-primary-color
      &:hover
        background-color: dark-primary-color-hover
      &:active
        background-color: dark-primary-color-active

    .vlist .vcard .vhead .vsys
      background-color: dark-primary-color

    a:hover,
    .vlist .vcard .vh .vmeta .vat
      color: #ffffff

    .vlist .vcard .vcontent.expand:before
      background: linear-gradient(180deg, rgba(37,41,54,0), rgba(37,41,54,1))

    .vlist .vcard .vcontent.expand:after
      background: rgba(37, 41, 54, 1)

    .vlist .vcard .vh,
    .vlist .vcard .vquote
      border-color: dark-primary-color-hover

    .vcontent,
    .vcount,
    .vinfo,
    .vcard .vhead .vnick
      color: dark-font-color

  // ── 评论：Gitalk ───────────────────────────────────────────
  .gt-container
    .gt-header-textarea,
    .gt-comment-content,
    .gt-meta
      background-color: dark-primary-color !important
      color: dark-font-color !important
      border-color: dark-primary-color-hover !important

    .gt-btn
      background-color: dark-primary-color-hover
      border-color: dark-primary-color-hover
      color: dark-font-color

    .gt-btn:hover
      background-color: dark-primary-color-active

    .gt-comment-username
      color: rgb(82, 153, 224) !important

    .gt-comment-date,
    .gt-comment-like-count
      color: dark-font-secondary !important

    .gt-comment-body
      color: dark-font-color !important

    .gt-header-preview
      background-color: dark-primary-color
      color: dark-font-color

  // ── 代码高亮 (atom-one-dark) ───────────────────────────────
  .hljs
    display: block
    overflow-x: auto
    padding: 0.5em
    color: #abb2bf
    background: #282c34

  .hljs-comment,
  .hljs-quote
    color: #5c6370
    font-style: italic

  .hljs-doctag,
  .hljs-keyword,
  .hljs-formula
    color: #c678dd

  .hljs-section,
  .hljs-name,
  .hljs-selector-tag,
  .hljs-deletion,
  .hljs-subst
    color: #e06c75

  .hljs-literal
    color: #56b6c2

  .hljs-string,
  .hljs-regexp,
  .hljs-addition,
  .hljs-attribute,
  .hljs-meta-string
    color: #98c379

  .hljs-built_in,
  .hljs-class .hljs-title
    color: #e6c07b

  .hljs-attr,
  .hljs-variable,
  .hljs-template-variable,
  .hljs-type,
  .hljs-selector-class,
  .hljs-selector-attr,
  .hljs-selector-pseudo,
  .hljs-number
    color: #d19a66

  .hljs-symbol,
  .hljs-bullet,
  .hljs-link,
  .hljs-meta,
  .hljs-selector-id,
  .hljs-title
    color: #61aeee

  .hljs-emphasis
    font-style: italic

  .hljs-strong
    font-weight: bold

  .hljs-link
    text-decoration: underline
