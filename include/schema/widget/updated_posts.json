{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "/widget/updated_posts.json",
    "description": "Recently updated posts widget configurations",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "const": "updated_posts"
        },
        "position": {
            "type": "string",
            "enum": ["left", "right"]
        },
        "limit": {
            "type": "integer",
            "default": 5,
            "description": "Number of posts to display"
        }
    },
    "required": ["type", "position"]
}